# ===== AgentOS Environment Variables =====
# Copy to .env and fill in values. NEVER commit .env

# --- Environment ---
ENVIRONMENT=development

# --- LLM Providers (free tiers) ---
# Groq free tier: console.groq.com (free, generous RPM)
GROQ_API_KEY=gsk_...
# OpenRouter free models (suffix :free): openrouter.ai/keys (free, rate-limited)
OPENROUTER_API_KEY=sk-or-...
# Gemini free tier: aistudio.google.com/apikey (15 RPM on flash)
GEMINI_API_KEY=AIza...

LLM_DEFAULT_CASCADE=speed
# Optional model overrides — see packages/llm/agentos_llm/config.py FREE_MODEL_ALTERNATIVES
# MODEL_GROQ=llama-3.1-8b-instant
# MODEL_OPENROUTER=qwen/qwen-2.5-72b-instruct:free
# MODEL_GEMINI=gemini-2.5-flash

# --- Supabase (AgentOS internal: chat sessions, messages, RAG vectors) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentos

# --- User business database (for /database/* endpoints) ---
# Connect AgentOS agents to your own data. Optional.
# Examples:
#   postgres://user:pass@host:5432/db
#   mysql://user:pass@host:3306/db
#   sqlite:///path/to/file.db
DATABASE_URL_USER=

# --- Vector Store ---
VECTOR_BACKEND=faiss   # or pgvector for production with DATABASE_URL

# --- Embedding model ---
# Default = all-MiniLM-L6-v2 (384 dim, ~80MB, runs on CPU, no API key).
# Switch to a stronger model when you need better recall. Make sure the
# pgvector column dim in supabase/migrations/002_pgvector.sql matches.
#
# API-based (uses the API key already in this file — no model download):
#   gemini-embedding-001     3072 dim*  ★ best free option, multilingual,
#                                       uses GEMINI_API_KEY (free tier ~1500 RPD).
#                                       *configurable via EMBEDDING_DIM (768/1536/3072).
#   text-embedding-004       768 dim    legacy free Gemini, simpler.
#
# Self-hosted (no API key, downloads model the first time):
#   BAAI/bge-m3                       1024 dim   ★ best CPU+multilingual self-host
#   intfloat/multilingual-e5-large    1024 dim   solid multilingual
#   BAAI/bge-large-en-v1.5            1024 dim   English-only, very strong
#   Qwen/Qwen3-Embedding-8B           7168 dim   needs ~24GB GPU
#   nvidia/NV-Embed-v2                4096 dim   needs GPU, non-commercial license
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: when EMBEDDING_MODEL=gemini-embedding-001, truncate the
# Matryoshka embedding to fewer dimensions (768 / 1536 / 3072). Smaller
# = cheaper storage + faster similarity, slight quality drop.
# EMBEDDING_DIM=3072

# --- Auth + Rate limits ---
AUTH_REQUIRED=false
RATE_LIMIT_PER_MINUTE=60

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=123456:ABC...
# Default chat IDs for notifications (comma-separated)
TELEGRAM_CHAT_IDS=

# --- Email notifications (SMTP) ---
# Works with Gmail (port 465), Brevo, SendGrid, Resend, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
EMAIL_RECIPIENTS=

# --- Deployment URLs ---
BACKEND_URL=http://localhost:8000
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- Go API ---
GO_API_PORT=8080

# --- PocketBase ---
POCKETBASE_URL=http://localhost:8090

# --- OpenRouter app metadata (optional, sent in X-Title header) ---
OPENROUTER_REFERER=https://agentos.dev
OPENROUTER_APP_NAME=AgentOS
