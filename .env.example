# ===== AgentOS Environment Variables =====
# Copy to .env and fill in values. NEVER commit .env

# --- Environment ---
ENVIRONMENT=development

# --- LLM Providers (free tiers) ---
# Groq free tier: console.groq.com (free, generous RPM)
GROQ_API_KEY=gsk_...
# OpenRouter free models (suffix :free): openrouter.ai/keys (free, rate-limited)
OPENROUTER_API_KEY=sk-or-...
# Gemini free tier: aistudio.google.com/apikey (15 RPM on flash)
GEMINI_API_KEY=AIza...

LLM_DEFAULT_CASCADE=speed
# Optional model overrides — see packages/llm/agentos_llm/config.py FREE_MODEL_ALTERNATIVES
# MODEL_GROQ=llama-3.1-8b-instant
# MODEL_OPENROUTER=qwen/qwen-2.5-72b-instruct:free
# MODEL_GEMINI=gemini-2.5-flash

# --- Supabase (AgentOS internal: chat sessions, messages, RAG vectors) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentos

# --- User business database (for /database/* endpoints) ---
# Connect AgentOS agents to your own data. Optional.
# Examples:
#   postgres://user:pass@host:5432/db
#   mysql://user:pass@host:3306/db
#   sqlite:///path/to/file.db
DATABASE_URL_USER=

# --- Vector Store ---
VECTOR_BACKEND=faiss   # or pgvector for production with DATABASE_URL

# --- Auth + Rate limits ---
AUTH_REQUIRED=false
RATE_LIMIT_PER_MINUTE=60

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=123456:ABC...
# Default chat IDs for notifications (comma-separated)
TELEGRAM_CHAT_IDS=

# --- Email notifications (SMTP) ---
# Works with Gmail (port 465), Brevo, SendGrid, Resend, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
EMAIL_RECIPIENTS=

# --- Deployment URLs ---
BACKEND_URL=http://localhost:8000
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- Go API ---
GO_API_PORT=8080

# --- PocketBase ---
POCKETBASE_URL=http://localhost:8090

# --- OpenRouter app metadata (optional, sent in X-Title header) ---
OPENROUTER_REFERER=https://agentos.dev
OPENROUTER_APP_NAME=AgentOS
